# ──────────────────────────────────────────────────────────────────────────────
# AI Talent Scout Pro — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to source control.
# ──────────────────────────────────────────────────────────────────────────────

# App
APP_NAME=AI Talent Scout Pro
APP_VERSION=2.0.0
DEBUG=false
ENVIRONMENT=production

# Security — CHANGE THESE IN PRODUCTION
SECRET_KEY=REPLACE-WITH-64-CHAR-RANDOM-SECRET-KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
# SQLite (dev/testing):
DATABASE_URL=sqlite+aiosqlite:///./talent_scout.db
SYNC_DATABASE_URL=sqlite:///./talent_scout.db
# PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://user:password@db:5432/talent_scout
# SYNC_DATABASE_URL=postgresql://user:password@db:5432/talent_scout

# CORS — comma-separated origins
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# File Upload
MAX_UPLOAD_SIZE_MB=10
UPLOAD_DIR=uploads

# ML
ML_MODELS_DIR=ml_models
SENTENCE_MODEL_NAME=all-MiniLM-L6-v2

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs

# Redis (optional — leave empty to disable caching)
REDIS_URL=
